# APIFY (Instagram scraping)
APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxx

# Google Cloud / Vertex AI
GCP_PROJECT=your-gcp-project-id
GCP_LOCATION=us-central1

# Firebase / Firestore (Service Account JSON)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CREDENTIALS_PATH=data/firebase_service_account.json

# Gmail API OAuth
GMAIL_SENDER_EMAIL=your-email@gmail.com
GMAIL_CREDENTIALS_PATH=data/gmail_credentials.json
GMAIL_TOKEN_PATH=data/gmail_token.json

# Brand
BRAND_NAME=yzt.digital
BRAND_DESC=yzt.digital, KOBİ ve esnaf odaklı dijital pazarlama ajansı.
CAMPAIGN_BRIEF=Dijital pazarlama ve AI araçları konusunda içerik üreticileriyle işbirliği.

# Pipeline settings
MIN_FOLLOWERS=1000
MAX_FOLLOWERS=500000
MIN_AI_SCORE=6.0
EMAIL_DELAY_SECONDS=30
REPLY_CHECK_INTERVAL=3600
