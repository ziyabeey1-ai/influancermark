# ── Influencer Hunter - .env Şablonu ──────────────────
# Bu dosyayı .env olarak kopyala ve değerleri doldur

# APIFY (instagram scraper)
# → https://console.apify.com/account/integrations
APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxx

# GOOGLE CLOUD / VERTEX AI (Gemini)
# → https://console.cloud.google.com
GCP_PROJECT=your-gcp-project-id
GCP_LOCATION=us-central1

# HUNTER.IO (email bul)
# → https://hunter.io/api-keys  (ücretsiz: 25 arama/ay)
HUNTER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SENDGRID (email gönder)
# → https://app.sendgrid.com/settings/api_keys  (ücretsiz: 100/gün)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDER_EMAIL=outreach@yzt.digital
SENDER_NAME=yzt.digital Ekibi

# MARKA AYARLARI
BRAND_NAME=yzt.digital
BRAND_DESC=yzt.digital, KOBİ ve esnaf odaklı dijital pazarlama ajansı.
CAMPAIGN_BRIEF=Dijital pazarlama ve AI araçları konusunda içerik üreticileriyle işbirliği.

# BOT AYARLARI
MIN_FOLLOWERS=1000       # Minimum takipçi sayısı
MAX_FOLLOWERS=500000     # Maximum takipçi sayısı
MIN_AI_SCORE=6.0         # Minimum AI uygunluk skoru (0-10)
EMAIL_DELAY_SECONDS=30   # Emailler arası bekleme (rate limit)
REPLY_CHECK_INTERVAL=3600 # Yanıt kontrol sıklığı (saniye)
